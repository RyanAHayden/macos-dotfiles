#!/usr/bin/env bash

PLUGIN_DIR="$CONFIG_DIR/plugins"
THEME_FILE="$CONFIG_DIR/theme.sh"

if [ -f "$THEME_FILE" ]; then
  source "$THEME_FILE"
else
  echo "SketchyBar theme file not found: $THEME_FILE" >&2
  exit 1
fi

sketchybar --bar position="$BAR_POSITION" \
  margin="$BAR_MARGIN" \
  y_offset="$BAR_Y_OFFSET" \
  corner_radius="$BAR_CORNER_RADIUS" \
  height="$BAR_HEIGHT" \
  color="$BAR_COLOR" \
  topmost="$BAR_TOPMOST"

sketchybar --default \
  padding_left="$ITEM_PADDING_LEFT" \
  padding_right="$ITEM_PADDING_RIGHT" \
  icon.font="$ICON_FONT" \
  label.font="$LABEL_FONT" \
  background.drawing="$ITEM_BACKGROUND_DRAWING" \
  icon.color="$TEXT_COLOR" \
  label.color="$TEXT_COLOR" \
  icon.padding_right="$ICON_PADDING_RIGHT" \
  icon.highlight_color="$ACCENT_COLOR" \
  label.highlight_color="$ACCENT_COLOR"

sketchybar --add event window_change

for i in $(seq 1 "$SPACE_COUNT"); do
  sketchybar --add space space.$i left \
    --set space.$i \
    associated_space=$i \
    drawing=off \
    icon=$i \
    icon.color="$TEXT_COLOR" \
    label.color="$TEXT_COLOR" \
    script="$PLUGIN_DIR/spaces.sh" \
    --subscribe space.$i window_change
done

sketchybar --add item clock right \
  --set clock background.drawing="$ITEM_BACKGROUND_DRAWING" icon.drawing=off update_freq="$CLOCK_UPDATE_FREQ" label.color="$TEXT_COLOR" script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --set battery background.drawing="$ITEM_BACKGROUND_DRAWING" icon="$BATTERY_ICON" update_freq="$BATTERY_UPDATE_FREQ" icon.color="$TEXT_COLOR" label.color="$TEXT_COLOR" script="$PLUGIN_DIR/battery.sh"

# sketchybar --add item ram right \
#   --set ram background.drawing="$ITEM_BACKGROUND_DRAWING" icon="$RAM_ICON" update_freq="$RAM_UPDATE_FREQ" icon.color="$TEXT_COLOR" label.color="$TEXT_COLOR" script="$PLUGIN_DIR/ram.sh"

# sketchybar --add item cpu right \
#   --set cpu background.drawing="$ITEM_BACKGROUND_DRAWING" icon="$CPU_ICON" update_freq="$CPU_UPDATE_FREQ" icon.color="$TEXT_COLOR" label.color="$TEXT_COLOR" script="$PLUGIN_DIR/cpu.sh"

sketchybar --update
